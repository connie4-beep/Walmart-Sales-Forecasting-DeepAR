build_dept_day_data <- function(sales_dt, calendar_df, price_dt) {
  id_part <- sales_dt[, .(store_id, item_id, dept_id)]
  d_cols <- grep("^d_", names(sales_dt), value = TRUE)
  
  out_list <- vector("list", length(d_cols))
  
  for (i in seq_along(d_cols)) {
    dcol <- d_cols[i]
    
    cal_row <- calendar_df[calendar_df$d == dcol, ]
    wk_i    <- cal_row$wm_yr_wk[1]
    date_i  <- cal_row$date[1]
    year_i  <- cal_row$year[1]
    month_i <- cal_row$month[1]
    wday_i  <- cal_row$wday[1]
    weekday_i <- cal_row$weekday[1]
    
    day_sales <- copy(id_part)
    day_sales[, sales := sales_dt[[dcol]]]
    day_sales <- day_sales[sales > 0]
    
    day_sales[, wm_yr_wk := wk_i]
    setkey(day_sales, store_id, item_id, wm_yr_wk)
    day_sales <- price_dt[day_sales]
    
    dept_day_i <- day_sales[!is.na(sell_price), .(
      total_sales = sum(sales, na.rm = TRUE),
      weighted_price = sum(sell_price * sales, na.rm = TRUE) / sum(sales, na.rm = TRUE)
    ), by = .(dept_id)]
    
    dept_day_i[, `:=`(
      date = date_i,
      year = year_i,
      month = month_i,
      wday = wday_i,
      weekday = weekday_i
    )]
    
    out_list[[i]] <- dept_day_i
  }
  
  dept_day <- rbindlist(out_list, use.names = TRUE, fill = TRUE)
  
  dept_day <- as.data.frame(dept_day) %>%
    arrange(dept_id, date) %>%
    group_by(dept_id) %>%
    mutate(
      sales_lag_1 = lag(total_sales),
      t = row_number()
    ) %>%
    ungroup()
  
  dept_day$month <- factor(dept_day$month)
  dept_day$weekday <- factor(dept_day$weekday)
  
  dept_day
}
