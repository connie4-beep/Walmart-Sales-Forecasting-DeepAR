#Sales_Test Data Preparation
build_dept_month_data <- function(sales_input, calendar, price) {
  calendar_dt <- as.data.table(copy(calendar))
  sales_dt <- as.data.table(copy(sales_input))
  price_dt <- as.data.table(copy(price))
  
  d_cols <- grep("^d_", names(sales_dt), value = TRUE)
  
  wk_to_ds <- split(calendar_dt$d, calendar_dt$wm_yr_wk)
  
  weekly_list <- vector("list", length(wk_to_ds))
  wks <- names(wk_to_ds)
  
  for (k in seq_along(wks)) {
    wk <- wks[k]
    ds <- wk_to_ds[[wk]]
    ds <- intersect(ds, d_cols)
    
    if (length(ds) == 0) next
    
    tmp <- sales_dt[, .(
      store_id = store_id,
      item_id = item_id,
      dept_id = dept_id,
      wm_yr_wk = as.integer(wk),
      weekly_sales = rowSums(.SD, na.rm = TRUE)
    ), .SDcols = ds]
    
    tmp <- tmp[weekly_sales > 0]
    weekly_list[[k]] <- tmp
  }
  
  sales_week <- rbindlist(weekly_list, use.names = TRUE, fill = TRUE)
  
  setkey(sales_week, store_id, item_id, wm_yr_wk)
  setkey(price_dt, store_id, item_id, wm_yr_wk)
  
  sales_price <- price_dt[sales_week]
  
  dept_week <- sales_price[!is.na(sell_price), .(
    total_sales = sum(weekly_sales, na.rm = TRUE),
    weighted_price = sum(sell_price * weekly_sales, na.rm = TRUE) /
      sum(weekly_sales, na.rm = TRUE)
  ), by = .(dept_id, wm_yr_wk)]
  
  week_calendar <- calendar_dt[, .(
    year = first(year),
    month = first(month)
  ), by = wm_yr_wk]
  
  setkey(dept_week, wm_yr_wk)
  setkey(week_calendar, wm_yr_wk)
  
  dept_week <- week_calendar[dept_week]
  
  dept_month <- dept_week[, .(
    total_sales = sum(total_sales, na.rm = TRUE),
    weighted_price_m = sum(weighted_price * total_sales, na.rm = TRUE) /
      sum(total_sales, na.rm = TRUE)
  ), by = .(dept_id, year, month)]
  
  dept_month <- as.data.frame(dept_month) %>%
    arrange(dept_id, year, month) %>%
    group_by(dept_id) %>%
    mutate(t = row_number()) %>%
    ungroup()
  
  dept_month$month <- factor(dept_month$month)
  
  return(dept_month)
}
