sales_test  <- read.csv("/Users/conniezhang/Desktop/ECON491/data/Sales Test Validation.csv", stringsAsFactors = FALSE)
price <- read.csv("sell_prices.csv", stringsAsFactors = FALSE)
calendar$date <- as.Date(calendar$date)
calendar$date <- as.Date(calendar$date)
