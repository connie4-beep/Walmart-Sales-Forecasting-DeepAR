setkey(price_dt, store_id, item_id, wm_yr_wk)
##Avoid Memory Usage, use function to combine
build_dept_day_data <- function(sales_dt, calendar_df, price_dt) {
id_part <- sales_dt[, .(store_id, item_id, dept_id)]
d_cols <- grep("^d_", names(sales_dt), value = TRUE)
out_list <- vector("list", length(d_cols))
for (i in seq_along(d_cols)) {
dcol <- d_cols[i]
cal_row <- calendar_df[calendar_df$d == dcol, ]
wk_i    <- cal_row$wm_yr_wk[1]
date_i  <- cal_row$date[1]
year_i  <- cal_row$year[1]
month_i <- cal_row$month[1]
wday_i  <- cal_row$wday[1]
weekday_i <- cal_row$weekday[1]
day_sales <- copy(id_part)
day_sales[, sales := sales_dt[[dcol]]]
day_sales <- day_sales[sales > 0]
day_sales[, wm_yr_wk := wk_i]
setkey(day_sales, store_id, item_id, wm_yr_wk)
day_sales <- price_dt[day_sales]
dept_day_i <- day_sales[!is.na(sell_price), .(
total_sales = sum(sales, na.rm = TRUE),
weighted_price = sum(sell_price * sales, na.rm = TRUE) / sum(sales, na.rm = TRUE)
), by = .(dept_id)]
dept_day_i[, `:=`(
date = date_i,
year = year_i,
month = month_i,
wday = wday_i,
weekday = weekday_i
)]
out_list[[i]] <- dept_day_i
}
dept_day <- rbindlist(out_list, use.names = TRUE, fill = TRUE)
dept_day <- as.data.frame(dept_day) %>%
arrange(dept_id, date) %>%
group_by(dept_id) %>%
mutate(
sales_lag_1 = lag(total_sales),
t = row_number()
) %>%
ungroup()
dept_day$month <- factor(dept_day$month)
dept_day$weekday <- factor(dept_day$weekday)
dept_day
}
###prepare train,test data for modeling
train_data <- build_dept_day_data(sales_train_dt, calendar, price_dt)
test_data  <- build_dept_day_data(sales_test_dt,  calendar, price_dt)
last_train_sales <- train_data %>%
group_by(dept_id) %>%
summarise(last_sales = dplyr::last(total_sales), .groups = "drop")
test_data <- test_data %>%
left_join(last_train_sales, by = "dept_id") %>%
group_by(dept_id) %>%
arrange(date, .by_group = TRUE) %>%
mutate(
sales_lag_1 = ifelse(row_number() == 1, last_sales, lag(total_sales))
) %>%
ungroup() %>%
select(-last_sales)
train_data2 <- train_data %>%
filter(!is.na(sales_lag_1), !is.na(weighted_price))
test_data2 <- test_data %>%
filter(!is.na(sales_lag_1), !is.na(weighted_price))
##building model
model_final <- lm(
log(total_sales + 1) ~ log(weighted_price) + sales_lag_1 + weekday + month + dept_id,
data = train_data2
)
summary(model_final)
test_data2$pred_log <- predict(model_final, newdata = test_data2)
test_data2$pred_sales <- exp(test_data2$pred_log) - 1
rmse <- sqrt(mean((test_data2$total_sales - test_data2$pred_sales)^2))
rmse
##Graph 1
ggplot(test_data2, aes(x = date)) +
geom_line(aes(y = total_sales, color = "Real"), linewidth = 1) +
geom_line(aes(y = pred_sales, color = "Predicted"), linewidth = 1) +
facet_wrap(~ dept_id, scales = "free_y") +
labs(
title = "Predicted vs Real Department Sales",
x = "Date",
y = "Sales",
color = ""
) +
theme_minimal()
##Graph 2 By IDX
plot_data <- test_data2 %>%
group_by(dept_id) %>%
mutate(
real_index = total_sales / mean(total_sales, na.rm = TRUE),
pred_index = pred_sales / mean(total_sales, na.rm = TRUE)
) %>%
ungroup()
ggplot(plot_data, aes(x = date)) +
geom_line(aes(y = real_index, color = "Real"), linewidth = 1) +
geom_line(aes(y = pred_index, color = "Predicted"), linewidth = 1) +
facet_wrap(~ dept_id, ncol = 3) +
labs(
title = "Predicted vs Real Department Sales (Indexed)",
x = "Date",
y = "Index (Mean = 1)",
color = ""
) +
theme_minimal()
##Graph 3 Total
summary_plot_data <- test_data2 %>%
group_by(date) %>%
summarise(
actual_sales = sum(total_sales, na.rm = TRUE),
predicted_sales = sum(pred_sales, na.rm = TRUE),
.groups = "drop"
)
ggplot(summary_plot_data, aes(x = date)) +
geom_line(aes(y = actual_sales, color = "Actual"), linewidth = 1.2) +
geom_line(aes(y = predicted_sales, color = "Predicted"),
linewidth = 1.2, linetype = "dashed") +
labs(
title = "Model Performance: Predicted vs Actual Sales",
subtitle = "Test Validation Period (Apr 25 – May 22, 2016)",
x = "Date",
y = "Total Units Sold",
color = "Metric"
) +
theme_minimal()
##building model
