library(dplyr)
# ---------------------------------------------------------
# Step 1: Extract Calendar Events and handle missing values
# ---------------------------------------------------------
# The calendar file usually has a column named 'event_name_1'
# We will replace blanks/NAs with "No_Event" and turn it into a factor
cal_events <- calendar %>%
select(date, event_name_1) %>%
mutate(
event_name_1 = ifelse(is.na(event_name_1) | event_name_1 == "", "No_Event", event_name_1),
event_name_1 = factor(event_name_1)
)
# Join these events to your existing training and test data
train_data3 <- train_data2 %>% left_join(cal_events, by = "date")
test_data3 <- test_data2 %>% left_join(cal_events, by = "date")
# ---------------------------------------------------------
# Step 2: Add the 7-Day Weekly Lag
# ---------------------------------------------------------
# We group by dept_id and shift the sales down by 7 rows
train_data3 <- train_data3 %>%
group_by(dept_id) %>%
arrange(date, .by_group = TRUE) %>%
mutate(sales_lag_7 = lag(total_sales, 7)) %>%
ungroup() %>%
filter(!is.na(sales_lag_7)) # Remove the first 7 days that now have NAs
# Do the exact same for the test set
test_data3 <- test_data3 %>%
group_by(dept_id) %>%
arrange(date, .by_group = TRUE) %>%
mutate(sales_lag_7 = lag(total_sales, 7)) %>%
ungroup() %>%
# If any NAs exist in the test lag, fill them with the last known lag to avoid dropping test rows
mutate(sales_lag_7 = ifelse(is.na(sales_lag_7), mean(sales_lag_7, na.rm=TRUE), sales_lag_7))
# ---------------------------------------------------------
# Step 3: Estimate the "Super Improved" Model
# ---------------------------------------------------------
model_super_improved <- lm(
log(total_sales + 1) ~ log(weighted_price) + sales_lag_1 + sales_lag_7 +
weekday + month + dept_id + event_name_1,
data = train_data3
)
summary(model_super_improved)
##Graph 1
ggplot(test_data2, aes(x = date)) +
geom_line(aes(y = total_sales, color = "Real"), linewidth = 1) +
geom_line(aes(y = pred_sales, color = "Predicted"), linewidth = 1) +
facet_wrap(~ dept_id, scales = "free_y") +
labs(
title = "Predicted vs Real Department Sales",
x = "Date",
y = "Sales",
color = ""
) +
theme_minimal()
##Graph 2 By IDX
plot_data <- test_data2 %>%
group_by(dept_id) %>%
mutate(
real_index = total_sales / mean(total_sales, na.rm = TRUE),
pred_index = pred_sales / mean(total_sales, na.rm = TRUE)
) %>%
ungroup()
ggplot(plot_data, aes(x = date)) +
geom_line(aes(y = real_index, color = "Real"), linewidth = 1) +
geom_line(aes(y = pred_index, color = "Predicted"), linewidth = 1) +
facet_wrap(~ dept_id, ncol = 3) +
labs(
title = "Predicted vs Real Department Sales (Indexed)",
x = "Date",
y = "Index (Mean = 1)",
color = ""
) +
theme_minimal()
##Graph 3 Total
summary_plot_data <- test_data2 %>%
group_by(date) %>%
summarise(
actual_sales = sum(total_sales, na.rm = TRUE),
predicted_sales = sum(pred_sales, na.rm = TRUE),
.groups = "drop"
)
ggplot(summary_plot_data, aes(x = date)) +
geom_line(aes(y = actual_sales, color = "Actual"), linewidth = 1.2) +
geom_line(aes(y = predicted_sales, color = "Predicted"),
linewidth = 1.2, linetype = "dashed") +
labs(
title = "Model Performance: Predicted vs Actual Sales",
subtitle = "Test Validation Period (Apr 25 – May 22, 2016)",
x = "Date",
y = "Total Units Sold",
color = "Metric"
) +
theme_minimal()
# Step 4: Calculate RMSE for the "Super Improved" Model
# 1. Generate predictions on the log scale using test_data3
test_data3$pred_log_super <- predict(model_super_improved, newdata = test_data3)
# 2. Reverse the log transformation to get actual sales units
test_data3$pred_super_improved <- exp(test_data3$pred_log_super) - 1
# 3. Calculate the RMSE
rmse_super_improved <- sqrt(mean((test_data3$total_sales - test_data3$pred_super_improved)^2, na.rm = TRUE))
# Print the final RMSE
cat("Super Improved RMSE: ", round(rmse_super_improved, 2), "\n")
library(dplyr)
# 1. Get the events
cal_events <- calendar %>%
select(date, event_name_1) %>%
mutate(
event_name_1 = ifelse(is.na(event_name_1) | event_name_1 == "", "No_Event", event_name_1),
event_name_1 = factor(event_name_1)
)
# 2. Join to your original, clean data
train_data_events <- train_data2 %>% left_join(cal_events, by = "date")
test_data_events <- test_data2 %>% left_join(cal_events, by = "date")
# 3. Model just the events
model_events_only <- lm(
log(total_sales + 1) ~ log(weighted_price) + sales_lag_1 + weekday + month + dept_id + event_name_1,
data = train_data_events
)
# 4. Predict and check RMSE
test_data_events$pred_log <- predict(model_events_only, newdata = test_data_events)
test_data_events$pred_actual <- exp(test_data_events$pred_log) - 1
rmse_events <- sqrt(mean((test_data_events$total_sales - test_data_events$pred_actual)^2, na.rm = TRUE))
print(paste("Events-Only RMSE:", round(rmse_events, 2)))
summary(model_events_only)
rmse_events <- sqrt(mean((test_data_events$total_sales - test_data_events$pred_actual)^2, na.rm = TRUE))
print(paste("Events-Only RMSE:", round(rmse_events, 2)))
install.packages(c("reticulate", "timetk", "modeltime", "modeltime.gluonts", "parsnip"))
